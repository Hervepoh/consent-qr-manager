# --- SERVER CONFIGURATION ---
PORT=3001
NODE_ENV=production

# --- DB CONFIGURATION ---
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=consent_manager

# --- SECURITY ---
# A strong random secret used to sign session tokens.
# Example: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here

# A strong random secret used to protect the /admin endpoints
# Example: openssl rand -base64 32
ADMIN_SECRET=your_super_secure_admin_secret_here

# Allowed frontend origin for CORS
# Example: https://consent.eneoapps.com
FRONTEND_URL=http://localhost:5173

# --- SERVICES ---
# Add your SMS provider configuration here if applicable
# SMS_API_KEY=...
