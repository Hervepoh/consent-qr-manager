# ══════════════════════════════════════════════════════════
#  consent-qr-manager — Variables d'environnement
#  Copiez ce fichier en .env et remplissez les valeurs
#  NE JAMAIS committer le .env en production !
# ══════════════════════════════════════════════════════════

# --- SERVEUR ---
PORT=3001
NODE_ENV=production

# --- BASE DE DONNÉES MYSQL ---
# Utilisé par le conteneur MySQL ET le serveur Express
DB_ROOT_PASSWORD=change_me_root_password
DB_HOST=db
DB_PORT=3306
DB_NAME=consent_manager
DB_USER=consent_user
DB_PASSWORD=change_me_db_password

# --- SÉCURITÉ ---
# Générer avec : openssl rand -base64 32
JWT_SECRET=change_me_jwt_secret_here

# Secret pour protéger les endpoints /admin
# Générer avec : openssl rand -base64 32
ADMIN_SECRET=change_me_admin_secret_here

# --- CORS ---
# URL publique du frontend (sans slash final)
# Exemple : https://consent.eneoapps.com
FRONTEND_URL=http://localhost

# --- SERVICES OPTIONNELS ---
# Fournisseur SMS (si activé)
# SMS_API_KEY=your_sms_api_key_here
# SMS_API_URL=https://api.your-sms-provider.com
